<Window
    x:Class="MelhorWindows.Desktop.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Auralis"
    Width="790"
    Height="450"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="Assets/AppIcon.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#091732" />
            <GradientStop Offset="1" Color="#050D1E" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#0D2148" />
            <GradientStop Offset="1" Color="#09142C" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#D6D2FF" />
            <GradientStop Offset="1" Color="#79C8FF" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="ProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#CFCBFF" />
            <GradientStop Offset="0.52" Color="#8ED3FF" />
            <GradientStop Offset="1" Color="#A8AFFF" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBrush" Color="#0B1733" />
        <SolidColorBrush x:Key="TextBrush" Color="#E4EBFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#98AFEA" />
        <SolidColorBrush x:Key="LineBrush" Color="#1A3565" />
        <DropShadowEffect x:Key="ShellShadow" BlurRadius="44" Color="#000000" Opacity="0.44" ShadowDepth="0" />
        <DropShadowEffect x:Key="HeroShadow" BlurRadius="36" Color="#6A83FF" Opacity="0.22" ShadowDepth="0" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="#112652" />
            <Setter Property="BorderBrush" Value="#254C8B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#091630" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Background" Value="#08122A" />
            <Setter Property="Foreground" Value="{StaticResource ProgressBrush}" />
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Storyboard.TargetName="ShellRoot"
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="1"
                        Duration="0:0:0.45" />
                    <DoubleAnimation
                        Storyboard.TargetName="ShellTranslate"
                        Storyboard.TargetProperty="Y"
                        From="16"
                        To="0"
                        Duration="0:0:0.45">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="HeroPane"
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="1"
                        BeginTime="0:0:0.08"
                        Duration="0:0:0.42" />
                    <DoubleAnimation
                        Storyboard.TargetName="HeroTranslate"
                        Storyboard.TargetProperty="Y"
                        From="12"
                        To="0"
                        BeginTime="0:0:0.08"
                        Duration="0:0:0.42">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="ContentPane"
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="1"
                        BeginTime="0:0:0.14"
                        Duration="0:0:0.42" />
                    <DoubleAnimation
                        Storyboard.TargetName="ContentTranslate"
                        Storyboard.TargetProperty="Y"
                        From="12"
                        To="0"
                        BeginTime="0:0:0.14"
                        Duration="0:0:0.42">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="HeroScale"
                        Storyboard.TargetProperty="ScaleX"
                        From="0.985"
                        To="1.025"
                        Duration="0:0:2.1"
                        AutoReverse="True"
                        RepeatBehavior="Forever" />
                    <DoubleAnimation
                        Storyboard.TargetName="HeroScale"
                        Storyboard.TargetProperty="ScaleY"
                        From="0.985"
                        To="1.025"
                        Duration="0:0:2.1"
                        AutoReverse="True"
                        RepeatBehavior="Forever" />
                    <DoubleAnimation
                        Storyboard.TargetName="AmbientGlowTop"
                        Storyboard.TargetProperty="Opacity"
                        From="0.26"
                        To="0.48"
                        Duration="0:0:2.8"
                        AutoReverse="True"
                        RepeatBehavior="Forever" />
                    <DoubleAnimation
                        Storyboard.TargetName="ProgressGlowTranslate"
                        Storyboard.TargetProperty="X"
                        From="-180"
                        To="360"
                        Duration="0:0:2.6"
                        RepeatBehavior="Forever" />
                    <DoubleAnimation
                        Storyboard.TargetName="ProgressGlow"
                        Storyboard.TargetProperty="Opacity"
                        From="0"
                        To="0.36"
                        Duration="0:0:0.55"
                        AutoReverse="True"
                        RepeatBehavior="Forever" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="24" Background="Transparent">
        <Border
            x:Name="ShellRoot"
            Background="{StaticResource ShellBrush}"
            BorderBrush="#173264"
            BorderThickness="1"
            CornerRadius="30"
            Effect="{StaticResource ShellShadow}"
            Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ShellTranslate" Y="16" />
            </Border.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="HeroPane"
                    Grid.Column="0"
                    Background="{StaticResource HeroBrush}"
                    CornerRadius="30,0,0,30"
                    Opacity="0"
                    Padding="30">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="HeroTranslate" Y="12" />
                    </Border.RenderTransform>

                    <Grid>
                        <Ellipse
                            x:Name="AmbientGlowTop"
                            Width="230"
                            Height="230"
                            Margin="-72,-76,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Fill="#3A67D5"
                            Opacity="0.36">
                            <Ellipse.Effect>
                                <BlurEffect Radius="72" />
                            </Ellipse.Effect>
                        </Ellipse>

                        <Ellipse
                            Width="190"
                            Height="190"
                            Margin="0,0,-70,-56"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Fill="#50B7D5"
                            Opacity="0.18">
                            <Ellipse.Effect>
                                <BlurEffect Radius="60" />
                            </Ellipse.Effect>
                        </Ellipse>

                        <Grid>
                            <Border
                                x:Name="HeroOrb"
                                Width="178"
                                Height="178"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,18,0,0"
                                Background="#102753"
                                BorderBrush="#2A5598"
                                BorderThickness="1"
                                CornerRadius="46"
                                Effect="{StaticResource HeroShadow}"
                                RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="HeroScale" />
                                </Border.RenderTransform>
                                <Grid>
                                    <Ellipse
                                        Width="110"
                                        Height="110"
                                        Fill="#4F77E2"
                                        Opacity="0.22" />
                                    <Rectangle
                                        Width="120"
                                        Height="120"
                                        RadiusX="34"
                                        RadiusY="34"
                                        Stroke="#6CCFFF"
                                        StrokeThickness="1"
                                        Opacity="0.16" />
                                    <Image
                                        Width="128"
                                        Height="128"
                                        Source="Assets/AppIcon.png"
                                        Stretch="Uniform" />
                                </Grid>
                            </Border>

                            <StackPanel VerticalAlignment="Bottom">
                                <Border
                                    Padding="12,6"
                                    HorizontalAlignment="Left"
                                    Background="#10244E"
                                    BorderBrush="#244A87"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#B8C7FF"
                                        Text="Auralis System Studio" />
                                </Border>

                                <TextBlock
                                    Margin="0,18,0,0"
                                    FontFamily="Segoe UI Variable Display"
                                    FontSize="32"
                                    FontWeight="Bold"
                                    Text="Auralis" />

                                <TextBlock
                                    Margin="0,10,0,0"
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="14"
                                    Text="Personalizacao, automacao e controle elegante do Windows com um fluxo rapido e limpo."
                                    TextWrapping="Wrap" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Icones locais" />
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Explorer" />
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Atualizacoes" />
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid x:Name="ContentPane" Grid.Column="1" Margin="34,28,34,24" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ContentTranslate" Y="12" />
                    </Grid.RenderTransform>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock
                                Foreground="{StaticResource MutedBrush}"
                                FontFamily="Segoe UI Variable Display"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="Inicializando ambiente" />
                            <TextBlock
                                x:Name="StepTitleTextBlock"
                                Margin="0,12,0,0"
                                FontFamily="Segoe UI Variable Display"
                                FontSize="30"
                                FontWeight="Bold"
                                Text="Preparando interface" />
                            <TextBlock
                                x:Name="StepDescriptionTextBlock"
                                Margin="0,10,0,0"
                                Foreground="{StaticResource MutedBrush}"
                                FontSize="14"
                                Text="Organizando o Auralis para abrir o fluxo principal com contexto real do usuario."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="14,10"
                            Margin="18,4,0,0"
                            VerticalAlignment="Top"
                            Background="#0D2148"
                            BorderBrush="#254A89"
                            BorderThickness="1"
                            CornerRadius="14">
                            <StackPanel>
                                <TextBlock
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Text="Fase atual" />
                                <TextBlock
                                    x:Name="PhaseBadgeTextBlock"
                                    Margin="0,4,0,0"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Text="Startup" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Margin="0,26,0,0"
                        Padding="18"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Carregamento real" />
                                <TextBlock
                                    x:Name="ProgressValueTextBlock"
                                    DockPanel.Dock="Right"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Text="08%" />
                            </DockPanel>

                            <Grid Grid.Row="1" Margin="0,14,0,0" ClipToBounds="True">
                                <ProgressBar
                                    x:Name="LoadingProgressBar"
                                    Maximum="100"
                                    Value="8" />
                                <Rectangle
                                    x:Name="ProgressGlow"
                                    Width="180"
                                    Margin="0,-10,0,-10"
                                    HorizontalAlignment="Left"
                                    Opacity="0">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#00FFFFFF" />
                                            <GradientStop Offset="0.50" Color="#55FFFFFF" />
                                            <GradientStop Offset="1" Color="#00FFFFFF" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="ProgressGlowTranslate" X="-180" />
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>

                            <TextBlock
                                x:Name="ProgressHintTextBlock"
                                Grid.Row="2"
                                Margin="0,12,0,0"
                                Foreground="{StaticResource MutedBrush}"
                                FontSize="12"
                                Text="A splash acompanha o startup real do app e fecha sozinha quando tudo estiver pronto."
                                TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="2" Margin="0,24,0,0" Columns="2" Rows="2">
                        <Border Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="#B9C7FF"
                                    Text="&#xE8B7;" />
                                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Icones locais" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="12"
                                    Text="Cada pasta guarda seu proprio arquivo de icone para continuar estavel em backup, copia e outras maquinas."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="#B9C7FF"
                                    Text="&#xE8E5;" />
                                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Fluxo rapido" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="12"
                                    Text="A janela principal abre direta no contexto da pasta, sem dashboard pesado nem informacao sobrando."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCardStyle}">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="#B9C7FF"
                                    Text="&#xE8A5;" />
                                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Atualizacao visivel" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="12"
                                    Text="O Auralis ja compara a build local com o GitHub e avisa quando aparecer algo novo para instalar."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="#B9C7FF"
                                    Text="&#xE713;" />
                                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Base expansivel" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="{StaticResource MutedBrush}"
                                    FontSize="12"
                                    Text="A identidade visual ja nasce preparada para futuras automacoes, perfis e ajustes mais profundos do Windows."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <DockPanel Grid.Row="3" Margin="0,20,0,0" LastChildFill="False">
                        <TextBlock
                            x:Name="FooterTextBlock"
                            Foreground="{StaticResource MutedBrush}"
                            FontSize="12"
                            Text="Desenvolvido por James B. - v1.0.0" />
                        <Border
                            DockPanel.Dock="Right"
                            Padding="12,6"
                            Background="#0F1F44"
                            BorderBrush="#203F77"
                            BorderThickness="1"
                            CornerRadius="12">
                            <TextBlock
                                Foreground="#BBC8FF"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Text="Startup premium" />
                        </Border>
                    </DockPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
