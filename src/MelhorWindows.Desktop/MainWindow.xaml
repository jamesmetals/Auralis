                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="AdminFeatureSettingsCard" Margin="0,0,0,14" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Admin" />
                                        <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Recursos do Windows" />
                                        <Grid Margin="0,14,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource PrimaryButtonStyle}" Click="EnableFeatureButton_Click" Content="Habilitar selecionada" />
                                            <Button Grid.Column="1" Margin="0,0,10,0" Click="DisableFeatureButton_Click" Content="Desabilitar selecionada" />
                                            <Button Grid.Column="2" Click="RefreshFeaturesButton_Click" Content="Atualizar lista" />
                                        </Grid>
                                        <ListView x:Name="FeatureListView">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11" Text="{Binding}" TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="AdminAuditSettingsCard" Margin="0,0,0,14" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Auditoria" />
                                        <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Histórico administrativo" />
                                        <Button Margin="0,14,0,10" Click="RefreshAuditButton_Click" Content="Atualizar auditoria" />
                                        <ListView x:Name="AuditListView">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11" Text="{Binding}" TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="UserSettingsInfoCard" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24" Visibility="Collapsed">
                                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Este perfil verá apenas recursos relevantes." TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ─────────────────────────────────────
                             PAGE: ResourcesView
                             ───────────────────────────────────── -->
                        <ScrollViewer x:Name="ResourcesView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recursos Complementares" />
                                <TextBlock Margin="0,6,0,0" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Ferramentas extras para o Windows" />
                                <TextBlock Margin="0,8,0,20" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Selecione uma ferramenta para instalar ou executar. Cada recurso funciona de forma independente." TextWrapping="Wrap" />

                                <WrapPanel>
                                    <!-- Card: Monitor de Pasta -->
                                    <Border Width="280" Margin="0,0,14,14" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <Border Width="44" Height="44" HorizontalAlignment="Left" CornerRadius="14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
