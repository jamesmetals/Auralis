<Window
    x:Class="MelhorWindows.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Auralis"
    Width="1100"
    Height="720"
    MinWidth="1100"
    MinHeight="720"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="Assets/AppIcon.ico"
    ResizeMode="CanMinimize"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackdropBrush" Color="#04060C" />
        <SolidColorBrush x:Key="BgBrush" Color="#091018" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0E161F" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#121C27" />
        <SolidColorBrush x:Key="DeepPanelBrush" Color="#0A1118" />
        <SolidColorBrush x:Key="WellBrush" Color="#090E14" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#121A24" />
        <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#16202C" />
        <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#192432" />
        <SolidColorBrush x:Key="InputBrush" Color="#0D141D" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#0E161F" />
        <SolidColorBrush x:Key="SidebarActiveBrush" Color="#171F2A" />
        <SolidColorBrush x:Key="TextBrush" Color="#F7F7F9" />
        <SolidColorBrush x:Key="MutedBrush" Color="#98A0AE" />
        <SolidColorBrush x:Key="SoftBrush" Color="#70798A" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#26303D" />
        <SolidColorBrush x:Key="DividerBrush" Color="#1E2834" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FD6004" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FFB17C" />
        <SolidColorBrush x:Key="PrimaryFgBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#AEE929" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#5ED9A6" />
        <SolidColorBrush x:Key="InfoBrush" Color="#74B9FF" />
        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#0A1118" />
            <GradientStop Offset="1" Color="#0C141C" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF7A2F" />
            <GradientStop Offset="1" Color="#FD6004" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF8A49" />
            <GradientStop Offset="1" Color="#FF6B17" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#F25454" />
            <GradientStop Offset="1" Color="#C81F1F" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF6767" />
            <GradientStop Offset="1" Color="#DC2F2F" />
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="AmbientOrbBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Offset="0" Color="#35FD6004" />
            <GradientStop Offset="0.7" Color="#10FD6004" />
            <GradientStop Offset="1" Color="#00FD6004" />
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="AmbientOrbAltBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Offset="0" Color="#22AEE929" />
            <GradientStop Offset="0.7" Color="#08AEE929" />
            <GradientStop Offset="1" Color="#00AEE929" />
        </RadialGradientBrush>
        <DropShadowEffect x:Key="ShellShadow" BlurRadius="36" Color="#000000" Opacity="0.42" ShadowDepth="6" RenderingBias="Performance" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Figtree" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimarySoftBrush}" />
            <Setter Property="FontFamily" Value="Figtree" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Figtree" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimarySoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.90" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryFgBrush}" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryFgBrush}" />
            <Setter Property="Background" Value="{StaticResource DangerButtonBrush}" />
            <Setter Property="BorderBrush" Value="#D23A3A" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource DangerButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="14,0" />
        </Style>
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}" />
            <Setter Property="BorderBrush" Value="#3A475A" />
        </Style>
        <Style x:Key="TabButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style x:Key="GameCardButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="Auto" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="24"
                            SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimarySoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontFamily" Value="Figtree" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="TextBoxBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="Background" Value="{StaticResource DeepPanelBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TextBoxBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="Figtree" />
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinWidth" Value="192" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MaxDropDownHeight" Value="240" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="ComboBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        Foreground="{StaticResource SoftBrush}"
                                        Text="&#xE70D;" />
                                </Grid>
                            </Border>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,8,0,0"
                                    Padding="6"
                                    Background="{StaticResource SurfaceElevatedBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource PrimarySoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Figtree" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <!-- History tiles: 68×68 -->
        <Style x:Key="RecentItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Tile" Width="68" Height="68" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Library tiles: 46×46 -->
        <Style x:Key="LibraryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Tile" Width="46" Height="46" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackdropBrush}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Fill="{StaticResource AmbientOrbBrush}" Canvas.Left="-120" Canvas.Top="-120" />
            <Ellipse Width="300" Height="300" Fill="{StaticResource AmbientOrbAltBrush}" Canvas.Left="860" Canvas.Top="12" />
            <Ellipse Width="240" Height="240" Fill="{StaticResource AmbientOrbBrush}" Canvas.Left="940" Canvas.Top="520" />
        </Canvas>

        <!-- ═══════════════════ MAIN SHELL ═══════════════════ -->
        <Border
            x:Name="MainShellBorder"
            Margin="24"
            Background="{StaticResource ShellBrush}"
            BorderBrush="{StaticResource DividerBrush}"
            BorderThickness="1"
            CornerRadius="30"
            Effect="{StaticResource ShellShadow}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ══════════════════════════════════════════
                     COLUMN 0: SIDEBAR
                     ══════════════════════════════════════════ -->
                <Border
                    Grid.Column="0"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="30,0,0,30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: Logo area -->
                        <Border
                            Grid.Row="0"
                            Padding="24,24,24,18"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="0,0,0,1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border
                                        Width="40" Height="40"
                                        CornerRadius="20"
                                        Background="{StaticResource PrimaryButtonBrush}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Figtree"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource PrimaryFgBrush}"
                                            Text="A" />
                                    </Border>
                                    <TextBlock
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Figtree"
                                        FontSize="19"
                                        FontWeight="Bold"
                                        Text="Auralis" />
                                </StackPanel>
                                <!-- Hidden subtitle for code compat -->
                                <TextBlock x:Name="PageSubtitleTextBlock" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <!-- Row 1: Nav items -->
                        <StackPanel Grid.Row="1" Margin="8,12,16,0">

                            <Button
                                x:Name="IconEditorNavButton"
                                Click="IconEditorNavButton_Click"
                                Style="{StaticResource ActiveNavButtonStyle}">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE8C8;" />
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Trocar Ícone" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="GameBoosterNavButton"
                                Margin="0,4,0,0"
                                Click="GameBoosterNavButton_Click"
                                Style="{StaticResource NavButtonStyle}">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE7FC;" />
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="JB GameBooster" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="ResourcesNavButton"
                                Margin="0,4,0,0"
                                Click="ResourcesNavButton_Click"
                                Style="{StaticResource NavButtonStyle}">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE74C;" />
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Recursos" />
                                </StackPanel>
                            </Button>

                            <Separator Margin="4,14,4,14" Background="{StaticResource DividerBrush}" />

                            <Button
                                x:Name="HomeNavButton"
                                Margin="0,0,0,0"
                                Click="HomeNavButton_Click"
                                Style="{StaticResource NavButtonStyle}">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE80F;" />
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Painel" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="SettingsNavButton"
                                Margin="0,4,0,0"
                                Click="SettingsNavButton_Click"
                                Style="{StaticResource NavButtonStyle}">
                                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE713;" />
                                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Configurações" />
                                </StackPanel>
                            </Button>

                        </StackPanel>

                        <!-- Row 2: User info -->
                        <Border
                            Grid.Row="2"
                            Padding="18,16"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="40" Height="40"
                                    Background="{StaticResource SurfaceStrongBrush}"
                                    CornerRadius="20">
                                    <TextBlock
                                        x:Name="UserInitialsTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource PrimaryBrush}" />
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="UserNameTextBlock" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="UserRoleSummaryTextBlock" Margin="0,2,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════
                     COLUMN 1: CONTENT AREA
                     ══════════════════════════════════════════ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46" />   <!-- title bar -->
                        <RowDefinition Height="Auto" /> <!-- notifications -->
                        <RowDefinition Height="*" />    <!-- pages -->
                    </Grid.RowDefinitions>

                    <!-- ── Row 0: Title bar ── -->
                    <Border
                        Grid.Row="0"
                        Padding="24,0,20,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="0,30,0,0"
                        MouseLeftButtonDown="WindowHeader_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Name="PageTitleTextBlock"
                                VerticalAlignment="Center"
                                FontFamily="Figtree"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="Trocar Ícone" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Hidden dummy buttons for code-behind compat -->
                                <Button
                                    x:Name="DashboardCloseButton"
                                    Click="DashboardCloseButton_Click"
                                    Visibility="Collapsed"
                                    Content="X" />
                                <Button
                                    Click="AccountButton_Click"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource RoundIconButtonStyle}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource PrimaryBrush}" Text="&#xE77B;" />
                                </Button>
                                <Button
                                    Click="WindowCloseButton_Click"
                                    Style="{StaticResource RoundIconButtonStyle}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource MutedBrush}" Text="&#xE711;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Row 1: Notifications ── -->
                    <StackPanel Grid.Row="1" Margin="16,10,16,0">
                        <Border
                            x:Name="StatusBorder"
                            Padding="14,10"
                            Background="#153126"
                            BorderBrush="#2E6352"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                            <TextBlock x:Name="StatusTextBlock" FontSize="12" Foreground="#A5F4CB" TextWrapping="Wrap" />
                        </Border>
                        <Border
                            x:Name="UpdateNoticeBorder"
                            Margin="0,8,0,0"
                            Padding="14,10"
                            Background="#101E31"
                            BorderBrush="#294666"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="UpdateNoticeTextBlock" Margin="0,0,12,0" FontSize="12" Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Click="OpenUpdateButton_Click" Content="Abrir GitHub" Style="{StaticResource PrimaryButtonStyle}" Height="30" FontSize="11" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ── Row 2: Pages ── -->
                    <Grid Grid.Row="2" Margin="16,10,16,14">

                        <!-- ─────────────────────────────────────
                             PAGE: IconEditorView (default visible)
                             ───────────────────────────────────── -->
                        <Grid x:Name="IconEditorView">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />   <!-- folder bar -->
                                <RowDefinition Height="10" />   <!-- gap -->
                                <RowDefinition Height="190" />  <!-- drop zone + actions -->
                                <RowDefinition Height="Auto" /> <!-- info + fit mode row -->
                                <RowDefinition Height="Auto" /> <!-- adjustment card -->
                                <RowDefinition Height="8" />    <!-- gap -->
                                <RowDefinition Height="Auto" /> <!-- recents -->
                                <RowDefinition Height="8" />    <!-- gap -->
                                <RowDefinition Height="*" />    <!-- library -->
                            </Grid.RowDefinitions>

                            <!-- ── Row 0: Folder bar ── -->
                            <Border Grid.Row="0" Padding="16,0" Background="{StaticResource PanelBrush}" CornerRadius="22">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="16"
                                        Foreground="{StaticResource SoftBrush}"
                                        Text="&#xE8B7;" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            x:Name="CurrentFolderNameTextBlock"
                                            MaxWidth="320"
                                            FontFamily="Figtree"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            x:Name="FolderPathTextBlock"
                                            Margin="8,0,0,0"
                                            MaxWidth="320"
                                            FontSize="11"
                                            Foreground="{StaticResource SoftBrush}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock x:Name="PreviewFolderNameTextBlock" Visibility="Collapsed" />

                                    <Button
                                        Grid.Column="2"
                                        Height="30"
                                        MinWidth="90"
                                        Padding="12,0"
                                        Click="ChooseFolderButton_Click"
                                        Content="Escolher pasta"
                                        FontSize="12" />
                                </Grid>
                            </Border>

                            <!-- ── Row 2: Drop zone (left) + Actions (right) ── -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="184" />
                                </Grid.ColumnDefinitions>

                                <!-- Drop zone -->
                                <Border Grid.Column="0" Padding="12" Background="{StaticResource PanelBrush}" CornerRadius="26">
                                    <Grid
                                        AllowDrop="True"
                                        DragOver="UploadDropZone_DragOver"
                                        Drop="UploadDropZone_Drop">
                                        <Border Background="{StaticResource WellBrush}" CornerRadius="20" />
                                        <Rectangle Margin="1" RadiusX="20" RadiusY="20" Stroke="{StaticResource BorderBrushSoft}" StrokeThickness="1.2" StrokeDashArray="6 6" />

                                        <Image
                                            x:Name="SourcePreviewImage"
                                            Margin="10"
                                            Opacity="0.50"
                                            Stretch="Uniform"
                                            RenderOptions.BitmapScalingMode="HighQuality" />

                                        <Button
                                            x:Name="ChooseImageButton"
                                            Height="Auto"
                                            MinWidth="0"
                                            Padding="0"
                                            Click="ChooseImageButton_Click"
                                            Style="{StaticResource GhostButtonStyle}">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border
                                                    Width="52" Height="52"
                                                    HorizontalAlignment="Center"
                                                    Background="{StaticResource PrimaryButtonBrush}"
                                                    CornerRadius="26">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="18"
                                                        Foreground="{StaticResource PrimaryFgBrush}"
                                                        Text="&#xE710;" />
                                                </Border>
                                                <TextBlock
                                                    x:Name="SourcePreviewPlaceholderTextBlock"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="Arraste ou clique para carregar" />
                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{StaticResource SoftBrush}"
                                                    Text="SVG · PNG · JPG · WEBP · ICO" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Actions panel -->
                                <Border Grid.Column="1" Margin="16,0,6,0" Padding="14" Background="{StaticResource PanelBrush}" CornerRadius="26">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="7" />
                                            <RowDefinition Height="30" />
                                        </Grid.RowDefinitions>

                                        <Border x:Name="SelectionSummaryCard" Grid.Row="0" Background="{StaticResource WellBrush}" CornerRadius="20" Visibility="Collapsed">
                                            <Grid>
                                                <Image x:Name="GeneratedPreviewImage" Margin="10" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                                <TextBlock
                                                    x:Name="GeneratedPreviewPlaceholderTextBlock"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="{StaticResource SoftBrush}"
                                                    Text="Prévia" />
                                            </Grid>
                                        </Border>

                                        <!-- Hidden compatibility elements -->
                                        <StackPanel Grid.Row="0" Visibility="Collapsed">
                                            <TextBlock x:Name="SelectedImageNameTextBlock" />
                                            <TextBlock x:Name="SelectedImageMetaTextBlock" />
                                            <TextBlock x:Name="PreviewModeTextBlock" />
                                            <Button x:Name="ReplaceImageButton" Click="ChooseImageButton_Click" Content="Trocar imagem" />
                                            <Button x:Name="UpdatePreviewButton" Click="UpdatePreviewButton_Click" Content="Atualizar" />
                                        </StackPanel>

                                        <Button
                                            x:Name="ApplyIconButton"
                                            Grid.Row="1"
                                            Click="ApplyIconButton_Click"
                                            Content="Aplicar"
                                            FontSize="12"
                                            Height="34"
                                            HorizontalAlignment="Stretch"
                                            MinWidth="0"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                        <Button
                                            x:Name="RestoreDefaultButton"
                                            Grid.Row="3"
                                            Click="RestoreDefaultButton_Click"
                                            Content="Restaurar"
                                            FontSize="11"
                                            Height="30"
                                            HorizontalAlignment="Stretch"
                                            MinWidth="0"
                                            Opacity="0.8" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- ── Row 3: Compact info row (fit mode) ── -->
                            <Border
                                x:Name="FitModeBar"
                                Grid.Row="3"
                                Visibility="Collapsed" />

                            <!-- ── Row 4: Adjustment card ── -->
                            <Border
                                x:Name="ImageAdjustmentCard"
                                Grid.Row="4"
                                Margin="0,8,0,0"
                                Padding="14,14"
                                Background="{StaticResource PanelBrush}"
                                CornerRadius="22"
                                Visibility="Collapsed">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="Ajuste da imagem" />
                                            <TextBlock
                                                x:Name="AdjustmentHintTextBlock"
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource MutedBrush}"
                                                TextWrapping="Wrap"
                                                VerticalAlignment="Center" />
                                        </StackPanel>
                                        <CheckBox
                                            x:Name="ManualCropCheckBox"
                                            Grid.Column="1"
                                            Margin="14,0,0,0"
                                            FontSize="11"
                                            Checked="ManualCropCheckBox_Changed"
                                            Content="Ajuste fino do corte"
                                            Unchecked="ManualCropCheckBox_Changed" />
                                    </Grid>
                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="12"
                                        Background="{StaticResource DeepPanelBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{StaticResource MutedBrush}"
                                                Text="Como adaptar a imagem ao ícone" />
                                            <ComboBox
                                                x:Name="FitModeComboBox"
                                                Margin="0,8,0,0"
                                                Height="30"
                                                Background="{StaticResource InputBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                FontSize="11"
                                                Foreground="{StaticResource TextBrush}"
                                                SelectionChanged="FitModeComboBox_SelectionChanged"
                                                SelectedIndex="0"
                                                Style="{StaticResource DarkComboBoxStyle}">
                                                <ComboBoxItem Content="Enquadrar ao quadrado" Tag="CropToSquare" />
                                                <ComboBoxItem Content="Mostrar imagem completa" Tag="FitInsideSquare" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        x:Name="ManualCropPanel"
                                        Margin="0,10,0,0"
                                        Padding="10"
                                        Background="{StaticResource DeepPanelBrush}"
                                        CornerRadius="18"
                                        Visibility="Collapsed">
                                        <WrapPanel>
                                            <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="X" /><TextBox x:Name="CropXTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                            <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Y" /><TextBox x:Name="CropYTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                            <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Largura" /><TextBox x:Name="CropWidthTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                            <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Altura" /><TextBox x:Name="CropHeightTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                            <Button Margin="0,16,0,0" Height="28" FontSize="11" Click="CenterCropButton_Click" Content="Centralizar" />
                                        </WrapPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ── Row 6: Recents ── -->
                            <StackPanel Grid.Row="6">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recentes" VerticalAlignment="Center" />
                                </Grid>
                                <ListBox
                                    x:Name="HistoryListBox"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    SelectionChanged="HistoryListBox_SelectionChanged">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <StaticResource ResourceKey="RecentItemStyle" />
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="48" Height="48">
                                                <Border Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource SurfaceBrush}" CornerRadius="14">
                                                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border
                                    x:Name="HistoryEmptyStateBorder"
                                    Margin="0,6,0,0"
                                    Padding="12,8"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="18"
                                    Visibility="Collapsed">
                                    <TextBlock FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Os ícones aplicados aparecerão aqui para reutilização rápida." />
                                </Border>
                            </StackPanel>

                            <!-- ── Row 8: Icon library (collapsible sections) ── -->
                            <Grid Grid.Row="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Search bar -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Bibliotecas" VerticalAlignment="Center" />
                                    <Grid Grid.Column="1">
                                        <TextBox x:Name="IconLibrarySearchTextBox" Padding="30,5,10,5" FontSize="11" TextChanged="IconLibrarySearchTextBox_TextChanged" />
                                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource SoftBrush}" Text="&#xE721;" IsHitTestVisible="False" />
                                    </Grid>
                                </Grid>

                                <!-- Ícones Genéricos (collapsible) -->
                                <StackPanel Grid.Row="2">
                                    <Button x:Name="ToggleGenericLibraryButton" Click="ToggleGenericLibrary_Click" Style="{StaticResource NavButtonStyle}" HorizontalContentAlignment="Stretch" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource PrimaryBrush}" Text="&#xE8B7;" VerticalAlignment="Center" />
                                                <TextBlock Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Text="Ícones Genéricos" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock x:Name="GenericLibraryArrow" Grid.Column="1" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource SoftBrush}" Text="&#xE70D;" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <ListBox
                                        x:Name="IconLibraryListBox"
                                        Margin="0,6,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                        SelectionChanged="IconLibraryListBox_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="10" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <StaticResource ResourceKey="LibraryItemStyle" />
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="34" Height="34">
                                                    <Border Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{Binding TileBackgroundBrush}" CornerRadius="10">
                                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Text="{Binding Glyph}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <!-- Ícones Personalizados (collapsible, starts collapsed) -->
                                <StackPanel Grid.Row="4">
                                    <Button x:Name="TogglePersonalLibraryButton" Click="TogglePersonalLibrary_Click" Style="{StaticResource NavButtonStyle}" HorizontalContentAlignment="Stretch" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{StaticResource SecondaryAccentBrush}" Text="&#xE77B;" VerticalAlignment="Center" />
                                                <TextBlock Margin="8,0,0,0" FontSize="12" FontWeight="SemiBold" Text="Ícones Personalizados" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock x:Name="PersonalLibraryArrow" Grid.Column="1" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource SoftBrush}" Text="&#xE76C;" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <ListBox
                                        x:Name="PersonalIconLibraryListBox"
                                        Margin="0,6,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                        Visibility="Collapsed"
                                        SelectionChanged="PersonalIconLibraryListBox_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="10" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <StaticResource ResourceKey="LibraryItemStyle" />
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="34" Height="34" ToolTip="{Binding DisplayName}">
                                                    <Border Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="10">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding PreviewPath}" Stretch="Uniform" />
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Border
                                        x:Name="PersonalLibraryEmptyBorder"
                                        Margin="0,6,0,0"
                                        Padding="12,8"
                                        Background="{StaticResource PanelBrush}"
                                        CornerRadius="18"
                                        Visibility="Collapsed">
                                        <TextBlock FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Seus ícones salvos aparecerão aqui. Aplique um ícone e clique em 'Salvar na biblioteca'." />
                                    </Border>
                                </StackPanel>
                            </Grid>

                        </Grid>

                        <!-- ─────────────────────────────────────
                             PAGE: HomeView
                             ───────────────────────────────────── -->
                        <ScrollViewer x:Name="HomeView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Dashboard do projeto" />
                                        <TextBlock x:Name="RolesTextBlock" Margin="0,8,0,0" FontFamily="Figtree" FontSize="18" FontWeight="Bold" />
                                        <TextBlock x:Name="SettingsSummaryTextBlock" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Use o menu lateral para navegar entre os módulos. O Trocar Ícone é o ponto central do Auralis." TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ─────────────────────────────────────
                             PAGE: HistoryView
                             ───────────────────────────────────── -->
                        <ScrollViewer x:Name="HistoryView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Histórico completo" />
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ElementName=HistoryListBox, Path=ItemsSource}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="160" Margin="0,0,12,12" Padding="16" Background="{StaticResource PanelBrush}" CornerRadius="22">
                                                <StackPanel>
                                                    <Border Height="96" Background="{StaticResource DeepPanelBrush}" CornerRadius="16">
                                                        <Image Source="{Binding PreviewImage}" Margin="14" Stretch="Uniform" />
                                                    </Border>
                                                    <TextBlock Margin="0,10,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Subtitle}" />
                                                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="{Binding AppliedText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ─────────────────────────────────────
                             PAGE: GameBoosterView
                             ───────────────────────────────────── -->
                        <Grid x:Name="GameBoosterView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Tab Navigation -->
                            <Border Grid.Row="0" Margin="0,0,0,16" Padding="4" Background="{StaticResource DeepPanelBrush}" CornerRadius="22" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="GbTabDashboardBtn" Content="Dashboard" Click="GbTab_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0"/>
                                    <Button x:Name="GbTabSystemBtn" Content="Sistema e Otimizacao" Click="GbTab_Click" Margin="4,0,0,0" Padding="16,8" Style="{StaticResource TabButtonStyle}" />
                                    <Button x:Name="GbTabGamesBtn" Content="Jogos especificos" Click="GbTab_Click" Margin="4,0,0,0" Padding="16,8" Style="{StaticResource TabButtonStyle}" />
                                    <Button x:Name="GbTabAiBtn" Content="Diagnostico Inteligente" Click="GbTab_Click" Margin="4,0,0,0" Padding="16,8" Style="{StaticResource TabButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <!-- Tab 1: Dashboard -->
                            <ScrollViewer Grid.Row="1" x:Name="GbContentDashboard" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="28">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="JB GameBooster" />
                                            <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="22" FontWeight="Bold" Text="Visao Geral do Sistema" />
                                            <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Base inicial do otimizador integrada ao dashboard atual. Navegue pelas sub-abas acima para recursos profundos." TextWrapping="Wrap" />
                                            
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Margin="0,0,10,12" Padding="16" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="22">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Otimizacao aplicada" />
                                                        <Grid Width="130" Height="130" Margin="0,12,0,0" HorizontalAlignment="Center">
                                                            <Ellipse Stroke="#173765" StrokeThickness="10" />
                                                            <Path x:Name="OptimizationGaugeArc" Stroke="#59E0A3" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock x:Name="OptimizationGaugeValueTextBlock" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display" FontSize="24" FontWeight="Bold" Text="0%" />
                                                                <TextBlock x:Name="OptimizationGaugeHintTextBlock" Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="0 de 0" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock x:Name="OptimizationGaugeSummaryTextBlock" Margin="0,12,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Sem leitura ainda." TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Margin="0,0,10,12" Padding="16" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="22">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="FPS estimado" />
                                                        <Grid Width="130" Height="130" Margin="0,12,0,0" HorizontalAlignment="Center">
                                                            <Ellipse Stroke="#173765" StrokeThickness="10" />
                                                            <Path x:Name="FpsGaugeArc" Stroke="#58C2FF" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock x:Name="FpsGaugeValueTextBlock" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display" FontSize="22" FontWeight="Bold" Text="0" />
                                                                <TextBlock x:Name="FpsGaugeHintTextBlock" Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="+0 FPS" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock x:Name="FpsGaugeSummaryTextBlock" Margin="0,12,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Atual 0 | Meta 0" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Margin="0,0,10,12" Padding="16" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="22">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="CPU" />
                                                        <Grid Width="130" Height="130" Margin="0,12,0,0" HorizontalAlignment="Center">
                                                            <Ellipse Stroke="#173765" StrokeThickness="10" />
                                                            <Path x:Name="CpuGaugeArc" Stroke="#FFB154" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock x:Name="CpuGaugeValueTextBlock" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display" FontSize="22" FontWeight="Bold" Text="0%" />
                                                                <TextBlock x:Name="CpuGaugeHintTextBlock" Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="apos 0%" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock x:Name="CpuGaugeSummaryTextBlock" Margin="0,12,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Sem leitura ainda." TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="3" Margin="0,0,0,12" Padding="16" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="22">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Memoria" />
                                                        <Grid Width="130" Height="130" Margin="0,12,0,0" HorizontalAlignment="Center">
                                                            <Ellipse Stroke="#173765" StrokeThickness="10" />
                                                            <Path x:Name="MemoryGaugeArc" Stroke="#F38D8D" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock x:Name="MemoryGaugeValueTextBlock" HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display" FontSize="22" FontWeight="Bold" Text="0%" />
                                                                <TextBlock x:Name="MemoryGaugeHintTextBlock" Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="0.0 / 0.0 GB" />
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock x:Name="MemoryGaugeSummaryTextBlock" Margin="0,12,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Sem leitura ainda." TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.1*" />
                                                    <ColumnDefinition Width="1.4*" />
                                                    <ColumnDefinition Width="2.1*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Margin="0,0,10,10" Padding="14,12" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="20">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Score atual" />
                                                        <TextBlock x:Name="GameBoosterScoreTextBlock" Margin="0,6,0,0" FontFamily="Segoe UI Variable Display" FontSize="24" FontWeight="Bold" Text="0%" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Margin="0,0,10,10" Padding="14,12" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="20">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Perfil sugerido" />
                                                        <TextBlock x:Name="GameBoosterProfileTextBlock" Margin="0,6,0,0" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Modo normal" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Margin="0,0,0,10" Padding="14,12" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="20">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Resumo" />
                                                        <TextBlock x:Name="GameBoosterSummaryTextBlock" Margin="0,6,0,0" FontSize="12" Text="Sem leitura ainda." TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <TextBlock x:Name="GameBoosterTelemetryFootnoteTextBlock" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="As leituras de CPU e memoria sao reais. FPS e economia apos otimizar sao estimativas heuristicas, nao benchmark direto." TextWrapping="Wrap" />
                                            
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Button x:Name="ApplyRecommendedGameBoosterButton" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Click="ApplyRecommendedGameBoosterButton_Click" Content="Aplicar recomendadas" Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button x:Name="RevertGameBoosterSessionButton" Grid.Row="0" Grid.Column="1" Margin="0,0,10,10" Click="RevertGameBoosterSessionButton_Click" Content="Desfazer ultima sessao" />
                                                <Button x:Name="RefreshGameBoosterButton" Grid.Row="0" Grid.Column="2" Margin="0,0,0,10" Click="RefreshGameBoosterButton_Click" Content="Atualizar leitura" />
                                                <Button x:Name="ShowAiReportButton" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" Click="ShowAiReportButton_Click" Content="Exibir diagnostico salvo" />
                                                <Button x:Name="ShowComputerReportButton" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,0" Click="ShowComputerReportButton_Click" Content="Exibir relatorio do sistema" />
                                            </Grid>

                                            <!-- Caixa de relatorios do dashboard -->
                                            <Border x:Name="GameBoosterReportBorder" Margin="0,14,0,0" Padding="16" Background="{StaticResource DeepPanelBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="24" Visibility="Collapsed">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Leituras e relatorios" />
                                                            <TextBlock x:Name="GameBoosterReportTitleTextBlock" Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Sem relatorio aberto" />
                                                            <TextBlock x:Name="GameBoosterReportSubtitleTextBlock" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Use os botoes acima para abrir o relatorio detalhado do sistema ou da analise inteligente." TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button x:Name="CloseGameBoosterReportButton" Grid.Column="1" Margin="12,0,0,0" Click="CloseGameBoosterReportButton_Click" Content="Fechar relatorio" />
                                                    </Grid>
                                                    <TextBox x:Name="GameBoosterReportTextBox" Margin="0,12,0,0" MinHeight="240" Background="{StaticResource SurfaceStrongBrush}" BorderThickness="0" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="12" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border x:Name="GameBoosterReadOnlyBorder" Margin="0,12,0,0" Padding="16" Background="#2E1C11" BorderBrush="#7E4D26" BorderThickness="1" CornerRadius="20" Visibility="Collapsed">
                                        <TextBlock FontSize="12" Foreground="#F0C28D" Text="Seu perfil pode visualizar o JB GameBooster, mas os botoes de aplicacao ficam bloqueados sem permissao administrativa de registro." TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Tab 2: Sistema e Otimizacao -->
                            <ScrollViewer Grid.Row="1" x:Name="GbContentSystem" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Seguranca do Sistema" />
                                            <CheckBox x:Name="GameBoosterRestorePointCheckBox" Margin="0,10,0,0" Checked="GameBoosterRestorePointCheckBox_Changed" Unchecked="GameBoosterRestorePointCheckBox_Changed" Content="Criar ponto de restauracao antes de aplicar alteracoes de sistema" />
                                            <TextBlock x:Name="GameBoosterSafetyHintTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Garante reversibilidade segura e integra das acoes que envolvem os drivers graficos ou Telemetria." TextWrapping="Wrap" />
                                            <TextBlock x:Name="GameBoosterLastSessionTextBlock" Margin="0,12,0,0" FontSize="12" Text="Nenhuma sessao registrada ainda." TextWrapping="Wrap" />
                                            <TextBlock x:Name="GameBoosterRestorePointInfoTextBlock" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Sem restore point recente." TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Tweaks Inviduais -->
                                    <Border Margin="0,12,0,0" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Tweaks Operacionais (Toggles Manuais)" />
                                            <ItemsControl x:Name="GameBoosterOptimizationItemsControl" Margin="0,12,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                                <Border Margin="0,0,0,12" Padding="16" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <WrapPanel>
                                                                        <Border Margin="0,0,8,8" Padding="8,3" Background="#233B66" CornerRadius="12">
                                                                            <TextBlock FontSize="10" Foreground="#E0EFFF" Text="{Binding Category}" />
                                                                        </Border>
                                                                        <Border Margin="0,0,8,8" Padding="8,3" Background="{Binding StatusBrush}" CornerRadius="0">
                                                                            <TextBlock FontSize="10" Foreground="White" FontWeight="Bold" Text="{Binding StatusText}" />
                                                                        </Border>
                                                                        <Border Margin="0,0,8,8" Padding="8,3" Background="#2A3441" CornerRadius="12">
                                                                            <TextBlock FontSize="10" Foreground="#EEEEEE" Text="{Binding ImpactText}" />
                                                                        </Border>
                                                                        <Border Margin="0,0,8,8" Padding="8,3" Background="#4C2B24" CornerRadius="12">
                                                                            <TextBlock FontSize="10" Foreground="#F5D0D0" Text="{Binding RiskText}" />
                                                                        </Border>
                                                                    </WrapPanel>
                                                                    <TextBlock Margin="0,2,0,0" FontFamily="Figtree" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Text="{Binding Title}" />
                                                                    <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="{StaticResource MutedBrush}" Text="{Binding Description}" TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource SoftBrush}" Text="{Binding CurrentText}" TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Text="{Binding RecommendedText}" TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="{Binding RestartText}" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                                <Button Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Tag="{Binding Id}" Click="ApplyGameBoosterOptimizationButton_Click" Content="{Binding ApplyButtonText}" IsEnabled="{Binding CanApply}" Style="{StaticResource PrimaryButtonStyle}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Tab 3: Jogos especificos -->
                            <ScrollViewer Grid.Row="1" x:Name="GbContentGames" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Jogos especificos" />
                                            <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Perfis dedicados por jogo" />
                                            <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="As automacoes e leituras dedicadas ficam separadas aqui. Escolha um card para abrir o painel completo do jogo selecionado." TextWrapping="Wrap" />

                                            <WrapPanel Margin="0,16,0,0">
                                                <Button
                                                    x:Name="RustGameCardButton"
                                                    Width="340"
                                                    Margin="0,0,14,14"
                                                    Tag="rust"
                                                    Click="GameSpecificCardButton_Click"
                                                    Style="{StaticResource GameCardButtonStyle}">
                                                    <StackPanel>
                                                        <Border Height="156" CornerRadius="22,22,0,0" ClipToBounds="True">
                                                            <Grid>
                                                                <Image Source="Assets/Games/rust-header.jpg" Stretch="UniformToFill" />
                                                                <Rectangle Fill="#880A1118" />
                                                                <StackPanel Margin="18" VerticalAlignment="Bottom">
                                                                    <Border x:Name="RustGameCardSelectionBadge" Width="98" Padding="8,4" Background="#A8FD6004" CornerRadius="999" Visibility="Collapsed">
                                                                        <TextBlock HorizontalAlignment="Center" FontSize="10" FontWeight="Bold" Text="SELECIONADO" />
                                                                    </Border>
                                                                    <TextBlock Margin="0,10,0,0" FontFamily="Segoe UI Variable Display" FontSize="24" FontWeight="Bold" Text="Rust" />
                                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource PrimaryFgBrush}" Text="Leitura dedicada, automacoes reversiveis e foco extremo" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <StackPanel Margin="18,16,18,18">
                                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Ultima otimizacao" />
                                                            <TextBlock x:Name="RustGameCardLastOptimizationTextBlock" Margin="0,6,0,0" FontSize="13" FontWeight="SemiBold" Text="Nenhuma automacao aplicada ainda." TextWrapping="Wrap" />
                                                            <TextBlock x:Name="RustGameCardStatusTextBlock" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Clique para abrir o painel dedicado do Rust." TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>

                                            <Border x:Name="GameSpecificSelectionHintBorder" Margin="0,4,0,0" Padding="18" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20">
                                                <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Selecione um card para abrir as otimizacoes, diagnosticos e acoes dedicadas do jogo." TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="RustGameDetailsBorder" Margin="0,12,0,0" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24" Visibility="Collapsed">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.1*" />
                                                    <ColumnDefinition Width="1*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Rust" />
                                                    <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="20" FontWeight="Bold" Text="Painel dedicado do Rust" />
                                                    <TextBlock x:Name="RustModuleSummaryTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Leitura consultiva para launch options, memoria e estabilidade do Rust." TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Margin="16,0,0,0" Padding="16" Background="{StaticResource SurfaceStrongBrush}" CornerRadius="20">
                                                    <StackPanel>
                                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Ultimo alinhamento" />
                                                        <TextBlock x:Name="RustOptimizationLastAppliedTextBlock" Margin="0,8,0,0" FontSize="13" FontWeight="SemiBold" Text="Nenhuma otimizacao automatica do Rust foi aplicada ainda." TextWrapping="Wrap" />
                                                        <TextBlock x:Name="RustOptimizationStatusTextBlock" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="O app pode aplicar ajustes em launch options do Steam e no client.cfg do Rust, um a um ou em lote." TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Border Margin="0,16,0,0" Padding="18" Background="#2A1313" BorderBrush="#D44747" BorderThickness="1" CornerRadius="22">
                                                <StackPanel>
                                                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Foreground="#FFD0D0" Text="FOCO EXTREMO" />
                                                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#F3BABA" Text="Fecha quase tudo que nao for essencial para o Rust, mantem Discord aberto se ele ja estiver rodando, encerra o Explorer e reduz o Auralis para um popup de controle." TextWrapping="Wrap" />
                                                    <Grid Margin="0,14,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="ExtremeRustFocusButton" Grid.Column="0" Click="ExtremeRustFocusButton_Click" Content="ATIVAR FOCO EXTREMO" Style="{StaticResource DangerButtonStyle}" />
                                                        <TextBlock Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Use apenas quando voce quiser dedicar a sessao inteira ao Rust e estiver pronto para fechar apps nao essenciais." TextWrapping="Wrap" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border x:Name="RustExtremeFocusConfirmationPanel" Margin="0,12,0,0" Padding="18" Background="#351111" BorderBrush="#F25454" BorderThickness="1" CornerRadius="22" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Foreground="#FFD2D2" Text="Confirmar FOCO EXTREMO" />
                                                    <TextBlock Margin="0,10,0,0" FontSize="12" Text="Se voce aceitar, o Auralis vai preparar uma sessao agressiva para o Rust. O Discord permanece aberto; o restante pode ser fechado sem salvar." TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,12,0,0" FontSize="12" FontWeight="SemiBold" Text="Ao confirmar, o app vai:" />
                                                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="1. Fechar processos e programas nao essenciais da sua sessao atual." TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="2. Encerrar o Explorer para liberar mais memoria e distracoes visuais." TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="3. Reduzir o Auralis para um popup com comando de restauracao do Explorer." TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="4. Abrir o Rust em seguida pelo Steam." TextWrapping="Wrap" />
                                                    <Grid Margin="0,16,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
