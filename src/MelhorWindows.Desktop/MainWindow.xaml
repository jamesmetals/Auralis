                                                    <ColumnDefinition Width="1*" />
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="AnalyzeAndApplyButton" Grid.Column="0" Grid.ColumnSpan="3" Click="AnalyzeAndApplyButton_Click" Content="Gerar diagnostico inteligente" Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button x:Name="TestLocalAiConnectionButton" Grid.Column="1" Margin="0,0,10,0" Click="TestLocalAiConnectionButton_Click" Content="Atualizar disponibilidade" Visibility="Collapsed" />
                                                <Button x:Name="SaveLocalAiSettingsButton" Grid.Column="2" Click="SaveLocalAiSettingsButton_Click" Content="Salvar configuracao" Visibility="Collapsed" />
                                            </Grid>
                                            <TextBlock x:Name="LocalAiCommandHintTextBlock" Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="A leitura cruza o estado atual do PC com o catalogo do booster para priorizar os ajustes com maior retorno." TextWrapping="Wrap" />

                                            <Border Margin="0,14,0,0" Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="20">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Resumo da leitura" />
                                                    <TextBlock x:Name="LocalAiAnalysisMetaTextBlock" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Nenhuma analise salva ainda." TextWrapping="Wrap" />
                                                    <TextBlock x:Name="LocalAiAnalysisSummaryTextBlock" Margin="0,8,0,0" FontSize="12" Text="Execute o diagnostico para receber um resumo pratico do estado atual do sistema." TextWrapping="Wrap" />
                                                    <ItemsControl x:Name="LocalAiRecommendationItemsControl" Margin="0,12,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,10" Padding="14" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18">
                                                                    <StackPanel>
                                                                        <TextBlock FontFamily="Segoe UI Variable Display" FontSize="13" FontWeight="Bold" Text="{Binding Title}" />
                                                                        <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="{Binding Reason}" TextWrapping="Wrap" />
                                                                        <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource PrimaryBrush}" Text="{Binding SuggestedAction}" TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Painel de Confirmação (visível após análise, antes de aplicar) -->
