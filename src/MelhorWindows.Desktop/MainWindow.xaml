                                                                            <Button Grid.Column="1" Tag="{Binding Id}" Click="UndoRustOptimizationButton_Click" Content="{Binding UndoButtonText}" IsEnabled="{Binding CanUndo}" />
                                                                        </Grid>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,12,0,0" Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="20">
