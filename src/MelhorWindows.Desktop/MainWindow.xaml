                                <StackPanel>
                                    
                                    <!-- Diagnostico inteligente -->
                                    <Border Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Assistente de desempenho" />
                                            <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Leitura guiada do sistema" />
                                            <TextBlock x:Name="LocalAiStatusTextBlock" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="O modulo inteligente revisa gargalos do PC e sugere a melhor sequencia de otimizacao para esta maquina." TextWrapping="Wrap" />
                                            <Grid Margin="0,14,0,0" Visibility="Collapsed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="240" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Configuracao interna" />
                                                    <TextBox x:Name="LocalAiEndpointTextBox" Margin="0,8,0,0" Text="ColeSuaChaveDaAPI_AIzaSy..." />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Perfil interno" />
