<Window
    x:Class="MelhorWindows.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Auralis"
    Width="860"
    Height="580"
    MinWidth="860"
    MinHeight="580"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="Assets/AppIcon.ico"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#060E20" />
        <SolidColorBrush x:Key="PanelBrush" Color="#091634" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#0D214C" />
        <SolidColorBrush x:Key="DeepPanelBrush" Color="#071127" />
        <SolidColorBrush x:Key="WellBrush" Color="#050C1C" />
        <SolidColorBrush x:Key="TextBrush" Color="#DEE5FF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#91AAEB" />
        <SolidColorBrush x:Key="SoftBrush" Color="#5B74B1" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#1E3768" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#C0C1FF" />
        <SolidColorBrush x:Key="PrimaryFgBrush" Color="#2522B0" />
        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#0A1B40" />
            <GradientStop Offset="1" Color="#08142A" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#D9D7FF" />
            <GradientStop Offset="1" Color="#B5B7FF" />
        </LinearGradientBrush>
        <DropShadowEffect x:Key="ShellShadow" BlurRadius="36" Color="#000000" Opacity="0.40" ShadowDepth="0" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#143066" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryFgBrush}" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="#D2D2FF" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style x:Key="RoundIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#0E2149" />
            <Setter Property="BorderBrush" Value="#26477E" />
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#112A59" />
            <Setter Property="BorderBrush" Value="#32569F" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0B2047" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#0B2047" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <!-- History tiles: 68×68 (was 92) -->
        <Style x:Key="RecentItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Tile" Width="68" Height="68" Background="#0B1E44" BorderBrush="#183664" BorderThickness="1" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#102856" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Library tiles: 46×46 (was 66) -->
        <Style x:Key="LibraryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Tile" Width="46" Height="46" Background="#0B1A39" BorderBrush="#163261" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#122A59" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">

        <!-- ═══════════════════ MAIN SHELL ═══════════════════ -->
        <Border
            Margin="20"
            Background="{StaticResource ShellBrush}"
            BorderBrush="#173265"
            BorderThickness="1"
            CornerRadius="22"
            Effect="{StaticResource ShellShadow}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />   <!-- header -->
                    <RowDefinition Height="Auto" /> <!-- notifications -->
                    <RowDefinition Height="*" />    <!-- content -->
                </Grid.RowDefinitions>

                <!-- ── Header ── -->
                <Border
                    Grid.Row="0"
                    Padding="22,0"
                    Background="#101D42"
                    BorderBrush="#173265"
                    BorderThickness="0,0,0,1"
                    CornerRadius="22,22,0,0"
                    MouseLeftButtonDown="WindowHeader_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                x:Name="PageTitleTextBlock"
                                FontFamily="Segoe UI Variable Display"
                                FontSize="18"
                                FontWeight="Bold"
                                Text="Trocar icone" />
                            <!-- Subtitle kept in tree for code access but hidden -->
                            <TextBlock x:Name="PageSubtitleTextBlock" Visibility="Collapsed" />
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            Click="AccountButton_Click"
                            Style="{StaticResource RoundIconButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBrush}" Text="&#xE77B;" />
                        </Button>
                        <Button
                            Grid.Column="2"
                            Click="WindowCloseButton_Click"
                            Style="{StaticResource RoundIconButtonStyle}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource MutedBrush}" Text="&#xE711;" />
                        </Button>
                    </Grid>
                </Border>

                <!-- ── Notifications (status + update) ── -->
                <StackPanel Grid.Row="1" Margin="18,10,18,0">
                    <Border
                        x:Name="StatusBorder"
                        Padding="12,9"
                        Background="#102A22"
                        BorderBrush="#2A5946"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                        <TextBlock x:Name="StatusTextBlock" FontSize="12" Foreground="#A5F4CB" TextWrapping="Wrap" />
                    </Border>
                    <Border
                        x:Name="UpdateNoticeBorder"
                        Margin="0,8,0,0"
                        Padding="12,9"
                        Background="#12254C"
                        BorderBrush="#32569F"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="UpdateNoticeTextBlock" Margin="0,0,12,0" FontSize="12" Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Click="OpenUpdateButton_Click" Content="Abrir GitHub" Style="{StaticResource PrimaryButtonStyle}" Height="30" FontSize="11" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ══════════════════════════════════════════
                     MAIN CONTENT — no ScrollViewer, fixed rows
                     ══════════════════════════════════════════ -->
                <Grid Grid.Row="2" Margin="18,10,18,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />   <!-- folder bar -->
                        <RowDefinition Height="10" />   <!-- gap -->
                        <RowDefinition Height="140" />  <!-- drop zone + actions -->
                        <RowDefinition Height="Auto" /> <!-- info + fit mode row -->
                        <RowDefinition Height="Auto" /> <!-- adjustment card (collapsed) -->
                        <RowDefinition Height="10" />   <!-- gap -->
                        <RowDefinition Height="Auto" /> <!-- recentes -->
                        <RowDefinition Height="10" />   <!-- gap -->
                        <RowDefinition Height="*" />    <!-- biblioteca -->
                    </Grid.RowDefinitions>

                    <!-- ── Row 0: Folder bar ── -->
                    <Border Grid.Row="0" Padding="14,0" Background="{StaticResource PanelBrush}" CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Folder icon glyph -->
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="16"
                                Foreground="{StaticResource SoftBrush}"
                                Text="&#xE8B7;" />

                            <!-- Folder name + path -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    x:Name="CurrentFolderNameTextBlock"
                                    MaxWidth="220"
                                    FontFamily="Segoe UI Variable Display"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    x:Name="FolderPathTextBlock"
                                    Margin="8,0,0,0"
                                    MaxWidth="260"
                                    FontSize="11"
                                    Foreground="{StaticResource SoftBrush}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Hidden: PreviewFolderNameTextBlock (referenced in code) -->
                            <TextBlock x:Name="PreviewFolderNameTextBlock" Visibility="Collapsed" />

                            <Button
                                Grid.Column="2"
                                Height="30"
                                MinWidth="90"
                                Padding="12,0"
                                Click="ChooseFolderButton_Click"
                                Content="Escolher pasta"
                                FontSize="12" />
                        </Grid>
                    </Border>

                    <!-- ── Row 2: Drop zone (left) + Actions (right) ── -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="148" />
                        </Grid.ColumnDefinitions>

                        <!-- Drop zone -->
                        <Border Grid.Column="0" Padding="10" Background="{StaticResource PanelBrush}" CornerRadius="18">
                            <Grid
                                AllowDrop="True"
                                DragOver="UploadDropZone_DragOver"
                                Drop="UploadDropZone_Drop">
                                <Border Background="{StaticResource WellBrush}" CornerRadius="13" />
                                <Rectangle Margin="1" RadiusX="13" RadiusY="13" Stroke="#2C467E" StrokeThickness="1.2" StrokeDashArray="6 6" />

                                <!-- Source image preview (shown at 0.5 opacity when loaded) -->
                                <Image
                                    x:Name="SourcePreviewImage"
                                    Margin="10"
                                    Opacity="0.50"
                                    Stretch="Uniform"
                                    RenderOptions.BitmapScalingMode="HighQuality" />

                                <!-- Upload placeholder overlay -->
                                <Button
                                    x:Name="ChooseImageButton"
                                    Height="Auto"
                                    MinWidth="0"
                                    Padding="0"
                                    Click="ChooseImageButton_Click"
                                    Style="{StaticResource GhostButtonStyle}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border
                                            Width="40"
                                            Height="40"
                                            HorizontalAlignment="Center"
                                            Background="{StaticResource PrimaryButtonBrush}"
                                            CornerRadius="20">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="18"
                                                Foreground="{StaticResource PrimaryFgBrush}"
                                                Text="&#xE710;" />
                                        </Border>
                                        <TextBlock
                                            x:Name="SourcePreviewPlaceholderTextBlock"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="Arraste ou clique para carregar" />
                                        <TextBlock
                                            Margin="0,5,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="10"
                                            Foreground="{StaticResource SoftBrush}"
                                            Text="SVG · PNG · JPG · WEBP · ICO" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Actions panel -->
                        <Border Grid.Column="1" Margin="10,0,0,0" Padding="10" Background="{StaticResource PanelBrush}" CornerRadius="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />   <!-- generated preview -->
                                    <RowDefinition Height="34" />  <!-- Apply -->
                                    <RowDefinition Height="7" />
                                    <RowDefinition Height="30" />  <!-- Restore -->
                                </Grid.RowDefinitions>

                                <!-- Generated preview (row 0) -->
                                <Border x:Name="SelectionSummaryCard" Grid.Row="0" Background="#080F28" CornerRadius="11" Visibility="Collapsed">
                                    <Grid>
                                        <Image x:Name="GeneratedPreviewImage" Margin="10" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                        <TextBlock
                                            x:Name="GeneratedPreviewPlaceholderTextBlock"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            Foreground="{StaticResource SoftBrush}"
                                            Text="Prévia" />
                                    </Grid>
                                </Border>

                                <!-- Hidden compatibility elements (referenced in code) -->
                                <StackPanel Grid.Row="0" Visibility="Collapsed">
                                    <TextBlock x:Name="SelectedImageNameTextBlock" />
                                    <TextBlock x:Name="SelectedImageMetaTextBlock" />
                                    <TextBlock x:Name="PreviewModeTextBlock" />
                                    <Button x:Name="ReplaceImageButton" Click="ChooseImageButton_Click" Content="Trocar imagem" />
                                    <Button x:Name="UpdatePreviewButton" Click="UpdatePreviewButton_Click" Content="Atualizar" />
                                </StackPanel>

                                <Button
                                    x:Name="ApplyIconButton"
                                    Grid.Row="1"
                                    Click="ApplyIconButton_Click"
                                    Content="Aplicar"
                                    FontSize="12"
                                    Height="34"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                                <Button
                                    x:Name="RestoreDefaultButton"
                                    Grid.Row="3"
                                    Click="RestoreDefaultButton_Click"
                                    Content="Restaurar"
                                    FontSize="11"
                                    Height="30"
                                    Opacity="0.8" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── Row 3: Compact info row (filename + fit mode) ── -->
                    <Border Grid.Row="3" Margin="0,8,0,0" Padding="12,7" Background="{StaticResource PanelBrush}" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: fit mode + cancel link -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{StaticResource MutedBrush}"
                                    Text="Modo:"
                                    VerticalAlignment="Center" />
                                <ComboBox
                                    x:Name="FitModeComboBox"
                                    Margin="6,0,0,0"
                                    Height="26"
                                    FontSize="11"
                                    MinWidth="0"
                                    SelectionChanged="FitModeComboBox_SelectionChanged"
                                    SelectedIndex="0">
                                    <ComboBoxItem Content="Enquadrar ao quadrado" Tag="CropToSquare" />
                                    <ComboBoxItem Content="Mostrar imagem completa" Tag="FitInsideSquare" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Right: close link -->
                            <Button
                                Grid.Column="1"
                                Click="CancelButton_Click"
                                Content="Fechar"
                                FontSize="11"
                                Height="26"
                                MinWidth="60"
                                Padding="10,0"
                                Opacity="0.65" />
                        </Grid>
                    </Border>

                    <!-- ── Row 4: Framing adjustment (visible only for non-square images) ── -->
                    <Border
                        x:Name="ImageAdjustmentCard"
                        Grid.Row="4"
                        Margin="0,8,0,0"
                        Padding="12,10"
                        Background="{StaticResource PanelBrush}"
                        CornerRadius="14"
                        Visibility="Collapsed">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="AdjustmentHintTextBlock"
                                    FontSize="11"
                                    Foreground="{StaticResource MutedBrush}"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center" />
                                <CheckBox
                                    x:Name="ManualCropCheckBox"
                                    Grid.Column="1"
                                    Margin="14,0,0,0"
                                    FontSize="11"
                                    Checked="ManualCropCheckBox_Changed"
                                    Content="Ajuste fino do corte"
                                    Unchecked="ManualCropCheckBox_Changed" />
                            </Grid>
                            <Border
                                x:Name="ManualCropPanel"
                                Margin="0,10,0,0"
                                Padding="10"
                                Background="{StaticResource DeepPanelBrush}"
                                CornerRadius="10"
                                Visibility="Collapsed">
                                <WrapPanel>
                                    <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="X" /><TextBox x:Name="CropXTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                    <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Y" /><TextBox x:Name="CropYTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                    <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Largura" /><TextBox x:Name="CropWidthTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                    <StackPanel Margin="0,0,10,0"><TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Text="Altura" /><TextBox x:Name="CropHeightTextBox" Width="72" Margin="0,4,0,0" FontSize="11" LostFocus="CropField_LostFocus" /></StackPanel>
                                    <Button Margin="0,16,0,0" Height="28" FontSize="11" Click="CenterCropButton_Click" Content="Centralizar" />
                                </WrapPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Row 6: Ícones recentes ── -->
                    <StackPanel Grid.Row="6">
                        <Grid Margin="0,0,0,8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recentes" VerticalAlignment="Center" />
                        </Grid>
                        <ListBox
                            x:Name="HistoryListBox"
                            Background="Transparent"
                            BorderThickness="0"
                            SelectionChanged="HistoryListBox_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <StaticResource ResourceKey="RecentItemStyle" />
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="48" Height="48">
                                        <Border Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#101D38" CornerRadius="10">
                                            <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border
                            x:Name="HistoryEmptyStateBorder"
                            Margin="0,6,0,0"
                            Padding="12,8"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="12"
                            Visibility="Collapsed">
                            <TextBlock FontSize="11" Foreground="{StaticResource SoftBrush}" Text="Os ícones aplicados aparecerão aqui para reutilização rápida." />
                        </Border>
                    </StackPanel>

                    <!-- ── Row 8: Biblioteca de ícones ── -->
                    <Grid Grid.Row="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Biblioteca" VerticalAlignment="Center" />
                            <Grid Grid.Column="1">
                                <TextBox x:Name="IconLibrarySearchTextBox" Padding="30,5,10,5" FontSize="11" TextChanged="IconLibrarySearchTextBox_TextChanged" />
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource SoftBrush}" Text="&#xE721;" IsHitTestVisible="False" />
                            </Grid>
                        </Grid>

                        <ListBox
                            x:Name="IconLibraryListBox"
                            Grid.Row="2"
                            Background="Transparent"
                            BorderThickness="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            SelectionChanged="IconLibraryListBox_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="8" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <StaticResource ResourceKey="LibraryItemStyle" />
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="34" Height="34">
                                        <Border Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{Binding TileBackgroundBrush}" CornerRadius="7">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Text="{Binding Glyph}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════ DASHBOARD OVERLAY ═══════════════════ -->
        <Grid x:Name="DashboardOverlayRoot" Visibility="Collapsed">
            <Border Background="#7F030915" />
            <Border
                x:Name="DashboardPanel"
                Width="400"
                Margin="0,30,30,30"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="22"
                Effect="{StaticResource ShellShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="20,18" Background="#101D42" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" CornerRadius="22,22,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" Background="#112754" CornerRadius="19">
                                    <TextBlock x:Name="UserInitialsTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                                </Border>
                                <StackPanel Margin="10,1,0,0">
                                    <TextBlock x:Name="UserNameTextBlock" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock x:Name="UserRoleSummaryTextBlock" Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1" Click="DashboardCloseButton_Click" Style="{StaticResource RoundIconButtonStyle}">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource MutedBrush}" Text="&#xE711;" />
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="16,14,16,0">
                        <Button x:Name="HomeNavButton" Click="HomeNavButton_Click" Style="{StaticResource ActiveNavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE80F;" />
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Painel" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="HistoryNavButton" Margin="0,8,0,0" Click="HistoryNavButton_Click" Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE81C;" />
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Histórico" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SettingsNavButton" Margin="0,8,0,0" Click="SettingsNavButton_Click" Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Text="&#xE713;" />
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Text="Configurações" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="16,14,16,16">
                        <Grid x:Name="HomeView">
                            <StackPanel>
                                <Border Padding="16" Background="#0B1A39" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Dashboard do projeto" />
                                        <TextBlock x:Name="RolesTextBlock" Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" />
                                        <TextBlock x:Name="SettingsSummaryTextBlock" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Padding="16" Background="#0B1A39" CornerRadius="16">
                                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Text="A janela principal fica dedicada à troca rápida de ícone. Este painel existe para histórico completo, integrações e recursos administrativos." TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer x:Name="HistoryView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Histórico completo" />
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ElementName=HistoryListBox, Path=ItemsSource}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="160" Margin="0,0,12,12" Padding="14" Background="#0B1A39" CornerRadius="16">
                                                <StackPanel>
                                                    <Border Height="96" Background="#09162E" CornerRadius="12">
                                                        <Image Source="{Binding PreviewImage}" Margin="14" Stretch="Uniform" />
                                                    </Border>
                                                    <TextBlock Margin="0,10,0,0" FontSize="13" FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource MutedBrush}" Text="{Binding Subtitle}" />
                                                    <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="{Binding AppliedText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="SettingsView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border x:Name="IntegrationSettingsCard" Margin="0,0,0,14" Padding="16" Background="#0B1A39" CornerRadius="16" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Explorer" />
                                        <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Integração com clique direito" />
                                        <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Registre ou remova o atalho do Auralis no Explorer." TextWrapping="Wrap" />
                                        <WrapPanel Margin="0,14,0,0">
                                            <Button Style="{StaticResource PrimaryButtonStyle}" Click="RegisterVerbButton_Click" Content="Registrar no Explorer" />
                                            <Button Margin="10,0,0,0" Click="UnregisterVerbButton_Click" Content="Remover do Explorer" />
                                            <Button Margin="10,0,0,0" Click="CheckUpdatesButton_Click" Content="Verificar atualizações" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="AdminFeatureSettingsCard" Margin="0,0,0,14" Padding="16" Background="#0B1A39" CornerRadius="16" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Admin" />
                                        <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Recursos do Windows" />
                                        <WrapPanel Margin="0,14,0,10">
                                            <Button Style="{StaticResource PrimaryButtonStyle}" Click="EnableFeatureButton_Click" Content="Habilitar selecionada" />
                                            <Button Margin="10,0,0,0" Click="DisableFeatureButton_Click" Content="Desabilitar selecionada" />
                                            <Button Margin="10,0,0,0" Click="RefreshFeaturesButton_Click" Content="Atualizar lista" />
                                        </WrapPanel>
                                        <ListView x:Name="FeatureListView">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11" Text="{Binding}" TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="AdminAuditSettingsCard" Margin="0,0,0,14" Padding="16" Background="#0B1A39" CornerRadius="16" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Auditoria" />
                                        <TextBlock Margin="0,8,0,0" FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Histórico administrativo" />
                                        <Button Margin="0,14,0,10" Click="RefreshAuditButton_Click" Content="Atualizar auditoria" />
                                        <ListView x:Name="AuditListView">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11" Text="{Binding}" TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="UserSettingsInfoCard" Padding="16" Background="#0B1A39" CornerRadius="16" Visibility="Collapsed">
                                    <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Este perfil verá apenas recursos relevantes." TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════ BUSY OVERLAY ═══════════════════ -->
        <Grid x:Name="BusyOverlayRoot" Visibility="Collapsed">
            <Border Background="#9F040A17" />
            <Border
                Width="300"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#0C1B3D"
                BorderBrush="#284C8D"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel>
                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Processando..." />
                    <TextBlock x:Name="BusyOverlayTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Aplicando ícone e atualizando o Explorer..." TextWrapping="Wrap" />
                    <ProgressBar Margin="0,14,0,0" Height="4" IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
