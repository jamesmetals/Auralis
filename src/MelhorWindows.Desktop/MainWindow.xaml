                                                    <Border Padding="10,6" Background="#1A3D1A" CornerRadius="12" VerticalAlignment="Center">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#7AE582" Text="✓ Instalado" />
                                                    </Border>
                                                    <Button Margin="10,0,0,0" Click="UninstallFolderMonitorButton_Click" Content="Desinstalar" FontSize="11" Padding="10,6" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Card: Limpeza de Temporários -->
                                    <Border Width="280" Margin="0,0,14,14" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <Border Width="44" Height="44" HorizontalAlignment="Left" Background="#E74D3C" CornerRadius="14">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" Text="&#xE74D;" />
