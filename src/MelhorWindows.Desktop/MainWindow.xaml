                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,8" Padding="14,12" Background="#1A241B" BorderBrush="#314A35" BorderThickness="1" CornerRadius="18">
                                                                    <StackPanel>
                                                                        <TextBlock FontWeight="Bold" FontSize="13" Text="{Binding Title}" Foreground="{StaticResource TextBrush}" />
                                                                        <TextBlock Margin="0,5,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="{Binding Description}" TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Grid Margin="0,14,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="ConfirmApplyButton" Grid.Column="0" Margin="0,0,10,0" Click="ConfirmApplyButton_Click" Content="Confirmar e Aplicar" Style="{StaticResource PrimaryButtonStyle}" />
                                                        <Button x:Name="CancelApplyButton" Grid.Column="1" Click="CancelApplyButton_Click" Content="Cancelar" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,12,0,0" Padding="16" Background="{StaticResource SurfaceBrush}" CornerRadius="20">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Jogos especificos" />
                                            <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="As leituras dedicadas, automacoes reversiveis e o FOCO EXTREMO de cada jogo ficam na aba Jogos especificos para nao misturar com o booster geral." TextWrapping="Wrap" />
