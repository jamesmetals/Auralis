                                            <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Varre uma pasta e encontra arquivos duplicados por hash. Mostra grupos de duplicatas com tamanho total." TextWrapping="Wrap" MinHeight="54" />
                                            <Button x:Name="OpenDuplicateFinderButton" Margin="0,14,0,0" Click="OpenDuplicateFinderButton_Click" Content="Escanear pasta" Style="{StaticResource PrimaryButtonStyle}" />
                                            <TextBlock x:Name="DuplicateFinderResultTextBlock" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Card: Limpador de Menu de Contexto -->
                                    <Border Width="280" Margin="0,0,14,14" Padding="20" Background="{StaticResource PanelBrush}" CornerRadius="24">
                                        <StackPanel>
                                            <Border Width="44" Height="44" HorizontalAlignment="Left" Background="#8E44AD" CornerRadius="14">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" Text="&#xE712;" />
                                            </Border>
                                            <TextBlock Margin="0,14,0,0" FontFamily="Segoe UI Variable Display" FontSize="15" FontWeight="Bold" Text="Limpador de Menu de Contexto" />
                                            <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Lista todas as entradas do menu de contexto do Windows. Remova itens indesejados de programas desinstalados." TextWrapping="Wrap" MinHeight="54" />
                                            <Button x:Name="OpenContextMenuCleanerButton" Margin="0,14,0,0" Click="OpenContextMenuCleanerButton_Click" Content="Abrir painel" Style="{StaticResource PrimaryButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>

                                <!-- Temp Cleaner Confirmation Panel -->
                                <Border x:Name="TempCleanerConfirmPanel" Margin="0,0,0,14" Padding="20" Background="{StaticResource DeepPanelBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="24" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Preview da limpeza" />
                                        <TextBlock x:Name="TempCleanerPreviewTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ConfirmTempCleanButton" Grid.Column="0" Margin="0,0,10,0" Click="ConfirmTempCleanButton_Click" Content="Limpar agora" Style="{StaticResource PrimaryButtonStyle}" />
                                            <Button Grid.Column="1" Click="CancelTempCleanButton_Click" Content="Cancelar" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Startup Manager Panel -->
                                <Border x:Name="StartupManagerPanel" Margin="0,0,0,14" Padding="20" Background="{StaticResource DeepPanelBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="24" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Programas de inicialização" />
                                        <TextBlock x:Name="StartupManagerCountTextBlock" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <ItemsControl x:Name="StartupItemsControl" Margin="0,12,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="14,10" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Name}" />
                                                                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="{Binding Source}" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Tag="{Binding Key}" Click="ToggleStartupEntryButton_Click" Content="{Binding ToggleText}" Padding="10,6" IsEnabled="{Binding CanToggle}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Margin="0,8,0,0" Click="CloseStartupManagerPanel_Click" Content="Fechar painel" />
                                    </StackPanel>
                                </Border>

                                <!-- Duplicate Finder Results Panel -->
                                <Border x:Name="DuplicateFinderPanel" Margin="0,0,0,14" Padding="20" Background="{StaticResource DeepPanelBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="24" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Duplicatas encontradas" />
                                        <TextBlock x:Name="DuplicateFinderSummaryTextBlock" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <ItemsControl x:Name="DuplicateGroupsItemsControl" Margin="0,12,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="14,10" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18">
                                                        <StackPanel>
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding SizeText}" />
                                                            <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="{Binding PathsText}" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock
                                            x:Name="DuplicateFinderActionHintTextBlock"
                                            Margin="0,12,0,0"
                                            FontSize="11"
                                            Foreground="{StaticResource SoftBrush}"
                                            Text="A correção mantém 1 copia por grupo e move o restante para a Lixeira."
                                            TextWrapping="Wrap"
                                            Visibility="Collapsed" />
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button
                                                x:Name="ResolveDuplicateGroupsButton"
                                                Margin="0,0,10,0"
                                                Click="ResolveDuplicateGroupsButton_Click"
                                                Content="Mover excedentes para a Lixeira"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Visibility="Collapsed" />
                                            <Button Click="CloseDuplicateFinderPanel_Click" Content="Fechar painel" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Context Menu Cleaner Panel -->
                                <Border x:Name="ContextMenuCleanerPanel" Margin="0,0,0,14" Padding="20" Background="{StaticResource DeepPanelBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="24" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontFamily="Segoe UI Variable Display" FontSize="16" FontWeight="Bold" Text="Entradas do menu de contexto" />
                                        <TextBlock x:Name="ContextMenuCleanerCountTextBlock" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                        <ItemsControl x:Name="ContextMenuItemsControl" Margin="0,12,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="14,10" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" Text="{Binding Command}" TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Tag="{Binding KeyPath}" Click="RemoveContextMenuEntryButton_Click" Content="Remover" Padding="10,6" Style="{StaticResource DangerButtonStyle}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Margin="0,8,0,0" Click="CloseContextMenuCleanerPanel_Click" Content="Fechar painel" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                    <!-- End Row 2: Pages -->

                </Grid>
                <!-- End Column 1 -->

            </Grid>
        </Border>
        <!-- End main shell border -->

        <!-- ═══════════════════ INSTALL SUCCESS DIALOG ═══════════════════ -->
        <Grid x:Name="InstallSuccessOverlayRoot" Visibility="Collapsed">
            <Border Background="#99000000" />
            <Border
                Width="460"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource DeepPanelBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="28">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#27AE60" />
                                    <GradientStop Offset="1" Color="#1E8449" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White" Text="&#xE73E;" />
                        </Border>
                        <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display" FontSize="20" FontWeight="Bold" Text="Monitor de Pasta Instalado!" />
                    </StackPanel>
                    <TextBlock Margin="0,18,0,0" FontSize="14" FontWeight="SemiBold" Text="Como funciona:" />
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Text="1. Clique com o botão direito em qualquer pasta no Explorer" />
                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="2. Selecione 'Monitorar essa pasta'" />
                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="3. Uma pasta FolderMonitor_Logs será criada com o registro de todas as alterações" />
                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="O monitoramento roda em segundo plano enquanto a janela do monitor estiver aberta." />
                    </StackPanel>
                    <Button Margin="0,22,0,0" Click="CloseInstallSuccessDialog_Click" Content="Entendi ✓" Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════ SAVE TO LIBRARY DIALOG ═══════════════════ -->
        <Grid x:Name="SaveToLibraryOverlayRoot" Visibility="Collapsed">
            <Border Background="#99000000" />
            <Border
                Width="400"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource DeepPanelBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="28">
                <StackPanel>
                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Ícone aplicado com sucesso!" />
                    <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Deseja salvar esse ícone na sua biblioteca pessoal para reutilizar no futuro?" TextWrapping="Wrap" />
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="0,0,10,0" Click="SaveToPersonalLibraryButton_Click" Content="Salvar na biblioteca" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Grid.Column="1" Click="SkipSaveToLibraryButton_Click" Content="Não, obrigado" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════ BUSY OVERLAY ═══════════════════ -->
        <Grid x:Name="BusyOverlayRoot" Visibility="Collapsed">
            <Border Background="#A0040A17" />
            <Border
                Width="300"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="24">
                <StackPanel>
                    <TextBlock FontFamily="Figtree" FontSize="18" FontWeight="Bold" Text="Processando..." />
                    <TextBlock x:Name="BusyOverlayTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="Aplicando ícone e atualizando o Explorer..." TextWrapping="Wrap" />
                    <ProgressBar Margin="0,14,0,0" Height="4" IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ExtremeFocusOverlayRoot" Visibility="Collapsed">
            <Border
                x:Name="ExtremeFocusBalloonBorder"
                Padding="12,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#D44747"
                BorderThickness="1"
                CornerRadius="22"
                MouseEnter="ExtremeFocusBalloon_MouseEnter"
                MouseLeave="ExtremeFocusBalloon_MouseLeave"
                MouseLeftButtonDown="WindowHeader_MouseLeftButtonDown">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" Background="#F25454" CornerRadius="999" VerticalAlignment="Center" />
                        <TextBlock Margin="8,0,0,0" FontSize="11" FontWeight="Bold" Text="RUST EXTREMO" />
                    </StackPanel>

                    <StackPanel x:Name="ExtremeFocusExpandedContent" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Modo extremo" />
                        <TextBlock Margin="0,6,0,0" FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold" Text="Rust em foco" />
                        <TextBlock x:Name="ExtremeFocusStatusTextBlock" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="O Rust foi iniciado com o minimo possivel de distrações. Use os controles abaixo para restaurar o Explorer ou sair do modo extremo." TextWrapping="Wrap" />
                        <Border Margin="0,14,0,0" Padding="14" Background="#171F2A" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18">
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimarySoftBrush}" Text="Script de restauracao do Explorer" />
                                <TextBlock x:Name="ExtremeFocusRestoreScriptTextBlock" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource SoftBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="LaunchRustFromExtremeFocusButton" Grid.Column="0" Margin="0,0,10,10" Click="LaunchRustFromExtremeFocusButton_Click" Content="Abrir Rust novamente" Style="{StaticResource PrimaryButtonStyle}" />
                            <Button x:Name="RestoreExplorerAfterExtremeFocusButton" Grid.Column="1" Margin="0,0,0,10" Click="RestoreExplorerAfterExtremeFocusButton_Click" Content="Restaurar Explorer" />
                            <Button x:Name="ExitRustExtremeFocusButton" Grid.Column="0" Grid.ColumnSpan="2" Click="ExitRustExtremeFocusButton_Click" Content="Sair do modo extremo" Style="{StaticResource DangerButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
